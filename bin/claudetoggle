#!/usr/bin/env bash
# claudetoggle — manage Claude Code toggles.
#
# Subcommands: add, remove, list, on, off, update, uninstall, doctor, help.
# First-time install is via setup.sh (or `curl … | sh` against the raw URL).

set -o pipefail

CLAUDE_HOME=${CLAUDE_HOME:-$HOME/.claude}
CLAUDETOGGLE_HOME=${CLAUDETOGGLE_HOME:-${XDG_DATA_HOME:-$HOME/.local/share}/claudetoggle}
PREFIX=${PREFIX:-$HOME/.local}

# Resolve the lib for sourcing helpers. Prefer an explicit override; else
# look next to the binary (typical when run from $CLAUDETOGGLE_HOME/bin/);
# else fall back to the repo layout (running from a clone).
CLAUDETOGGLE_LIB=${CLAUDETOGGLE_LIB:-$(dirname "$(readlink -f "$0")")/../lib}
if [ ! -d "$CLAUDETOGGLE_LIB" ] && [ -d "$CLAUDETOGGLE_HOME/lib" ]; then
	CLAUDETOGGLE_LIB=$CLAUDETOGGLE_HOME/lib
fi

# shellcheck source=lib/scope.sh
. "$CLAUDETOGGLE_LIB/scope.sh"
# shellcheck source=lib/toggle.sh
. "$CLAUDETOGGLE_LIB/toggle.sh"
# shellcheck source=lib/hook_io.sh
. "$CLAUDETOGGLE_LIB/hook_io.sh"

# settings_merge.sh lives under scripts/ in the repo and gets copied into
# the data home's bin/ by setup.sh.
merge_lib=$(dirname "$(readlink -f "$0")")/../scripts/settings_merge.sh
[ -r "$merge_lib" ] || merge_lib=$CLAUDETOGGLE_HOME/bin/settings_merge.sh
# shellcheck source=scripts/settings_merge.sh
. "$merge_lib"

settings_file=$CLAUDE_HOME/settings.json

# Print a bold-ish heading. Skip ANSI when not on a TTY.
say() {
	if [ -t 1 ]; then
		printf '\033[1m%s\033[0m\n' "$*"
	else
		printf '%s\n' "$*"
	fi
}

die() {
	printf 'claudetoggle: %s\n' "$*" >&2
	exit 1
}

# Source a registry file in a subshell and emit selected metadata as
# pipe-delimited lines: TOGGLE_NAME|TOGGLE_SCOPE|TOGGLE_ON_MSG|TOGGLE_OFF_MSG.
# Used by `list` and per-toggle wiring routines without leaking vars.
read_toggle_meta() {
	local f=$1
	(
		# shellcheck disable=SC1090
		. "$f"
		printf '%s|%s|%s|%s\n' \
			"${TOGGLE_NAME:-}" "${TOGGLE_SCOPE:-}" \
			"${TOGGLE_ON_MSG:-}" "${TOGGLE_OFF_MSG:-}"
	)
}

# wire_toggle DIR — register one toggle dir. Validates metadata, symlinks
# slash-command markdown, merges TOGGLE_EXTRA_HOOKS, appends deny rules.
wire_toggle() {
	local dir=$1 name
	name=$(basename "$dir")
	local toggle_sh=$dir/toggle.sh
	[ -r "$toggle_sh" ] || die "no toggle.sh in $dir"

	(
		# shellcheck disable=SC1090
		. "$toggle_sh"
		[ "${TOGGLE_NAME:-}" = "$name" ] || {
			printf 'claudetoggle: %s declares TOGGLE_NAME=%q; expected %s.\n' \
				"$toggle_sh" "${TOGGLE_NAME:-}" "$name" >&2
			exit 1
		}
		[ "${TOGGLE_API:-}" = "1" ] || {
			printf 'claudetoggle: %s declares TOGGLE_API=%q; only 1 supported.\n' \
				"$toggle_sh" "${TOGGLE_API:-<unset>}" >&2
			exit 1
		}
	) || return 1

	local md_src=$dir/$name.md
	local md_dst=$CLAUDE_HOME/commands/$name.md
	mkdir -p "$CLAUDE_HOME/commands"
	if [ -r "$md_src" ]; then
		if [ -L "$md_dst" ] || [ ! -e "$md_dst" ]; then
			ln -snf "$md_src" "$md_dst"
		else
			printf 'claudetoggle: %s exists and is not a symlink; skipping.\n' "$md_dst" >&2
		fi
	fi

	# Source again to read the array in this shell.
	# shellcheck disable=SC2034
	local TOGGLE_NAME TOGGLE_API
	local TOGGLE_EXTRA_HOOKS=()
	# shellcheck disable=SC1090
	. "$toggle_sh"

	mapfile -t rules < <(deny_globs_for_toggle "$name")
	settings_with_lock settings_add_deny "$settings_file" "${rules[@]}"

	local idx=0 entry event matcher if_clause script script_path
	for entry in "${TOGGLE_EXTRA_HOOKS[@]}"; do
		IFS=$'\x1f' read -r event matcher if_clause script <<<"$entry"
		script_path=$CLAUDETOGGLE_HOME/toggles/$name/$script
		settings_with_lock settings_add_extra_hook \
			"$settings_file" "$name" "$idx" \
			"$event" "$matcher" "$if_clause" "$script_path"
		idx=$((idx + 1))
	done
}

# unwire_toggle NAME — reverse of wire_toggle for one toggle (does not
# remove the directory; that's a separate concern).
unwire_toggle() {
	local name=$1
	local md=$CLAUDE_HOME/commands/$name.md
	[ -L "$md" ] && rm -f "$md"
	if [ -e "$settings_file" ] && settings_check_valid "$settings_file"; then
		settings_with_lock settings_remove_tagged "$settings_file" "# claudetoggle:$name:"
		mapfile -t rules < <(deny_globs_for_toggle "$name")
		settings_with_lock settings_remove_deny "$settings_file" "${rules[@]}"
	fi
}

cmd_add() {
	local source=$1
	[ -n "$source" ] || die "add requires a toggle name or path. See: claudetoggle help"

	local src_dir name
	if [ -d "$source" ]; then
		src_dir=$(cd "$source" && pwd)
		name=$(basename "$src_dir")
	elif [ -d "$CLAUDETOGGLE_HOME/examples/$source" ]; then
		src_dir=$CLAUDETOGGLE_HOME/examples/$source
		name=$source
	else
		die "no toggle '$source' (not a directory and not a shipped example). Try: claudetoggle help"
	fi

	local dst_dir=$CLAUDETOGGLE_HOME/toggles/$name
	if [ -e "$dst_dir" ]; then
		die "$name is already registered at $dst_dir. Use 'claudetoggle remove $name' first."
	fi

	mkdir -p "$CLAUDETOGGLE_HOME/toggles"
	cp -r "$src_dir" "$dst_dir"
	if ! wire_toggle "$dst_dir"; then
		# Undo the copy; the toggle never registered cleanly.
		rm -rf "$dst_dir"
		exit 1
	fi
	printf 'claudetoggle: registered %s (scope: %s).\n' "$name" \
		"$(read_toggle_meta "$dst_dir/toggle.sh" | cut -d'|' -f2)"
}

cmd_remove() {
	local name=$1 keep_state=0
	shift 2>/dev/null || true
	while [ $# -gt 0 ]; do
		case $1 in
		--keep-state) keep_state=1 ;;
		*) die "remove: unknown argument $1" ;;
		esac
		shift
	done
	[ -n "$name" ] || die "remove requires a toggle name."

	local dir=$CLAUDETOGGLE_HOME/toggles/$name
	[ -d "$dir" ] || die "$name is not registered."

	unwire_toggle "$name"
	rm -rf "$dir"
	if [ "$keep_state" -eq 0 ]; then
		rm -rf "$CLAUDETOGGLE_HOME/state/$name"
	fi
	printf 'claudetoggle: removed %s.\n' "$name"
}

cmd_list() {
	local registry=$CLAUDETOGGLE_HOME/toggles
	if [ ! -d "$registry" ] || [ -z "$(toggle_files)" ]; then
		printf 'No toggles registered. Add one: claudetoggle add coauth\n'
		return 0
	fi
	printf '%-20s %-9s %s\n' NAME SCOPE STATE
	local f name scope on off active_rc
	while IFS= read -r f; do
		IFS='|' read -r name scope on off < <(read_toggle_meta "$f")
		: "$on" "$off"
		active_rc=0
		toggle_active "$scope" "$name" "$PWD" "${CLAUDE_SESSION_ID:-}" || active_rc=$?
		case $active_rc in
		0) printf '%-20s %-9s ON\n' "$name" "$scope" ;;
		1) printf '%-20s %-9s off\n' "$name" "$scope" ;;
		2) printf '%-20s %-9s n/a (no %s context)\n' "$name" "$scope" "$scope" ;;
		esac
	done < <(toggle_files)
}

cmd_on() {
	local name=$1
	[ -n "$name" ] || die "on requires a toggle name."
	local dir=$CLAUDETOGGLE_HOME/toggles/$name
	[ -d "$dir" ] || die "$name is not registered."
	IFS='|' read -r tname scope _on _off < <(read_toggle_meta "$dir/toggle.sh")
	[ -n "$scope" ] || die "$name: TOGGLE_SCOPE missing."
	if toggle_on "$scope" "$tname" "$PWD" "${CLAUDE_SESSION_ID:-}"; then
		printf 'claudetoggle: %s is now ON.\n' "$name"
	else
		die "$name requires a $scope context (PWD=$PWD, session=${CLAUDE_SESSION_ID:-})"
	fi
}

cmd_off() {
	local name=$1
	[ -n "$name" ] || die "off requires a toggle name."
	local dir=$CLAUDETOGGLE_HOME/toggles/$name
	[ -d "$dir" ] || die "$name is not registered."
	IFS='|' read -r tname scope _on _off < <(read_toggle_meta "$dir/toggle.sh")
	[ -n "$scope" ] || die "$name: TOGGLE_SCOPE missing."
	if toggle_off "$scope" "$tname" "$PWD" "${CLAUDE_SESSION_ID:-}"; then
		printf 'claudetoggle: %s is now off.\n' "$name"
	else
		die "$name requires a $scope context (PWD=$PWD, session=${CLAUDE_SESSION_ID:-})"
	fi
}

cmd_update() {
	local setup_url=https://raw.githubusercontent.com/spuddydev/claudetoggle/main/setup.sh
	if command -v curl >/dev/null 2>&1; then
		curl -sSfL "$setup_url" | sh
	elif command -v wget >/dev/null 2>&1; then
		wget -qO- "$setup_url" | sh
	else
		die "neither curl nor wget is available; install one and retry."
	fi
}

cmd_uninstall() {
	local purge=0
	while [ $# -gt 0 ]; do
		case $1 in
		--purge) purge=1 ;;
		*) die "uninstall: unknown argument $1" ;;
		esac
		shift
	done
	if [ -e "$settings_file" ] && settings_check_valid "$settings_file"; then
		settings_with_lock settings_remove_tagged "$settings_file" "# claudetoggle:"
	fi
	# Remove all per-toggle deny rules and slash-command symlinks.
	if [ -d "$CLAUDETOGGLE_HOME/toggles" ]; then
		local dir name
		for dir in "$CLAUDETOGGLE_HOME/toggles"/*/; do
			[ -d "$dir" ] || continue
			name=$(basename "${dir%/}")
			unwire_toggle "$name"
		done
	fi
	if [ "$purge" -eq 1 ]; then
		rm -f "$PREFIX/bin/claudetoggle"
		rm -rf "$CLAUDETOGGLE_HOME"
		printf 'claudetoggle: removed %s and the CLI binary.\n' "$CLAUDETOGGLE_HOME"
	else
		printf 'claudetoggle: settings unwired; data, state and CLI preserved at %s. Use --purge to remove everything.\n' \
			"$CLAUDETOGGLE_HOME"
	fi
}

cmd_doctor() {
	say 'claudetoggle: doctor'
	printf '  CLAUDE_HOME       = %s\n' "$CLAUDE_HOME"
	printf '  CLAUDETOGGLE_HOME = %s\n' "$CLAUDETOGGLE_HOME"
	printf '  CLAUDETOGGLE_LIB  = %s\n' "$CLAUDETOGGLE_LIB"
	printf '  PREFIX            = %s\n' "$PREFIX"
	printf '  CLI on PATH       = %s\n' "$(command -v claudetoggle 2>/dev/null || echo 'not found')"
	printf '\n'
	if [ -e "$settings_file" ]; then
		if settings_check_valid "$settings_file"; then
			local count
			count=$(jq '[.. | objects | select(has("command")) | .command | tostring | select(contains("# claudetoggle"))] | length' "$settings_file" 2>/dev/null)
			printf '  settings.json     = valid, %s claudetoggle hook entries\n' "${count:-0}"
		else
			printf '  settings.json     = MALFORMED — %s\n' "$settings_file"
		fi
	else
		printf '  settings.json     = missing (%s)\n' "$settings_file"
	fi
	printf '\n'
	cmd_list
	printf '\n'
	if [ -r "$CLAUDETOGGLE_HOME/debug.log" ]; then
		printf '  recent debug log (%s):\n' "$CLAUDETOGGLE_HOME/debug.log"
		tail -n 5 "$CLAUDETOGGLE_HOME/debug.log" | sed 's/^/    /'
	else
		printf '  debug log         = empty (set CLAUDETOGGLE_DEBUG=1 to populate)\n'
	fi
}

cmd_help() {
	cat <<EOF
claudetoggle — manage Claude Code toggles

Usage: claudetoggle <command> [args]

Commands:
  add <name|path>      register a shipped example or a local directory
  remove <name>        unregister and delete a toggle (use --keep-state to preserve state)
  list                 show registered toggles and their state
  on <name>            flip a toggle ON in the current scope
  off <name>           flip a toggle OFF in the current scope
  update               re-run the latest setup.sh
  uninstall            unwire claudetoggle (use --purge to also delete data)
  doctor               diagnostic dump
  help                 this message

First-time install: curl -sSfL https://raw.githubusercontent.com/spuddydev/claudetoggle/main/setup.sh | sh
EOF
}

cmd=${1:-help}
shift 2>/dev/null || true

case $cmd in
add) cmd_add "$@" ;;
remove | rm) cmd_remove "$@" ;;
list | ls) cmd_list "$@" ;;
on) cmd_on "$@" ;;
off) cmd_off "$@" ;;
update) cmd_update "$@" ;;
uninstall) cmd_uninstall "$@" ;;
doctor) cmd_doctor "$@" ;;
help | --help | -h) cmd_help ;;
*)
	printf 'claudetoggle: unknown command %q. See: claudetoggle help\n' "$cmd" >&2
	exit 2
	;;
esac
